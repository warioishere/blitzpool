{
  "name": "blitzpool",
  "version": "2.1.5",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "postinstall": "patch-package",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --passWithNoTests",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:cov": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:debug": "NODE_OPTIONS='--experimental-vm-modules' node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --passWithNoTests",
    "migrate:sqlite-to-pg": "ts-node --project tsconfig.scripts.json --transpile-only scripts/migrate-sqlite-to-pg.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.3",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-fastify": "^10.4.22",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/typeorm": "^10.0.2",
    "@scure/btc-signer": "^2.0.1",
    "async-mutex": "^0.5.0",
    "axios": "^1.4.0",
    "big.js": "^6.2.1",
    "bitcoin-address-validation": "^2.2.1",
    "bitcoinjs-lib": "^6.1.3",
    "bitcoinjs-message": "^2.2.0",
    "bs58": "^5.0.0",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "discord.js": "^14.11.0",
    "eventsource": "^4.0.0",
    "firebase-admin": "^12.7.0",
    "merkle-lib": "^2.0.10",
    "node-telegram-bot-api": "^0.61.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "redis": "^4.6.0",
    "reflect-metadata": "^0.1.13",
    "rpc-bitcoin": "^2.0.0",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.6",
    "tiny-secp256k1": "^2.2.3",
    "typeorm": "^0.3.29",
    "web-push": "^3.6.7",
    "zeromq": "6.0.0-beta.19"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/big.js": "^6.1.6",
    "@types/cron": "2.0.1",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^4.17.13",
    "@types/jest": "29.5.1",
    "@types/node": "18.16.12",
    "@types/node-telegram-bot-api": "^0.61.6",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "29.5.0",
    "patch-package": "8.0.0",
    "pg-mem": "^3.0.5",
    "prettier": "^2.3.2",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "29.1.0",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "allowJs": true
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@scure|@noble|micro-packed))"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
