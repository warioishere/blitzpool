# bitcoin node running in your private network 192.168.1.0/24
BITCOIN_RPC_URL=http://192.168.1.100

# bitcoin node running undockered on the same PC
# needs to add rpcallowip=172.16.0.0/12 to your bitcoin.conf
#BITCOIN_RPC_URL=http://host.docker.internal

BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_TIMEOUT=10000

# You can use this instead of BITCOIN_RPC_USER and BITCOIN_RPC_PASSWORD
BITCOIN_RPC_COOKIEFILE=

# Enable in bitcoin.conf with
# zmqpubrawblock=tcp://*:3000
# BITCOIN_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=3334
STRATUM_PORT=3333

#optional telegram bot
#TELEGRAM_BOT_TOKEN=

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional dev fee configuration
DEV_FEE_ADDRESS=
DEV_FEE_PERCENT=1.5
# mainnet | testnet
NETWORK=mainnet

API_SECURE=false
# Default is "Public-Pool", you can change it to any string it will be removed if it will make the block or coinbase script too big
POOL_IDENTIFIER="Public-Pool"

# Database configuration
# --- SQLite (default) ---
# Leave DB_TYPE unset or explicitly set to sqlite to continue using the bundled file database.
#SQLITE_DATABASE=./DB/public-pool.sqlite
#DB_TYPE=sqlite

# --- Postgres ---
# Switch to Postgres by setting DB_TYPE=postgres and providing the connection details below.
# Data is stored under ./full-setup/data/<network>/public-pool/pg when using the provided docker-compose stacks.
#PG_HOST=postgres
#PG_PORT=5432
#PG_USER=postgres
# Provide either PG_PASSWORD directly or PG_PASSWORD_FILE to read it from a mounted secret.
#PG_PASSWORD=postgres
#PG_DATABASE=public_pool
#PG_SSL=false
#PG_PASSWORD_FILE=/run/secrets/pg_password
#DB_RUN_MIGRATIONS=true
# When DB_RUN_MIGRATIONS=true the service also copies data from the legacy SQLite database on startup.
# Uncomment the line below to opt out and handle the migration manually with `npm run migrate:sqlite-to-pg`.
#DB_MIGRATE_SQLITE_ON_BOOT=false

# Optional block template refresh interval (ms)
#BLOCK_TEMPLATE_INTERVAL=30000
# Job and template retention time (ms)
JOB_RETENTION_MS=90000
# Desired number of shares per minute per worker (default: 6)
TARGET_SHARES_PER_MINUTE=6
# Interval for checking and adjusting miner difficulty (ms)
DIFFICULTY_CHECK_INTERVAL_MS=60000

# Performance Tuning - Phase 1 Optimizations
# Share totals cache flush interval (ms) - Higher = less DB writes, more data loss on crash
# Recommended: 1800000 (30 min) for production, 300000 (5 min) for development
SHARE_TOTALS_FLUSH_INTERVAL_MS=1800000

# Statistics batch write interval (ms) - How often to flush accumulated statistics to DB
# Recommended: 300000 (5 min) for production
STATISTICS_BATCH_WRITE_INTERVAL_MS=300000

# API cache TTLs (seconds) - Override defaults for specific endpoints
# Uncomment to customize individual endpoint cache durations
#API_CACHE_TTL_SITE_INFO=300
#API_CACHE_TTL_POOL_INFO=600
#API_CACHE_TTL_CORE_INFO=60
#API_CACHE_TTL_PEER_INFO=60
#API_CACHE_TTL_CHART=1800
#API_CACHE_TTL_SHARES=600
#API_CACHE_TTL_WORKERS=1800
#API_CACHE_TTL_ACCEPTED=600
#API_CACHE_TTL_REJECTED=600

# Performance Tuning - Phase 2 Optimizations (Redis + Pre-computed Aggregations)
# Redis cache configuration - Shared cache across PM2 cluster instances
# Leave REDIS_HOST empty to use in-memory cache (falls back automatically)
#REDIS_HOST=redis
#REDIS_PORT=6379
#REDIS_PASSWORD=
#REDIS_DB=0
#REDIS_TTL=600

# Pre-computed aggregations - Background jobs for expensive queries
# Set to 'false' to disable (useful for development)
ENABLE_AGGREGATION_SERVICE=true
# Pool stats aggregation interval (ms) - Default: 10 min
AGGREGATION_INTERVAL_POOL_STATS=600000
# Chart data aggregation interval (ms) - Default: 30 min
AGGREGATION_INTERVAL_CHART_DATA=1800000
