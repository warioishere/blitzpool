BITCOIN_RPC_URL=http://bitcoin
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_TIMEOUT=10000

# Enable in bitcoin.conf with
# zmqpubrawblock=tcp://*:3000
# BITCOIN_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=3334
STRATUM_PORT=3333

#block-template interval
BLOCK_TEMPLATE_INTERVAL=30000
JOB_RETENTION_MS=90000
# Desired number of shares per minute per worker (default: 6)
TARGET_SHARES_PER_MINUTE=6
# Interval for checking and adjusting miner difficulty (ms)
DIFFICULTY_CHECK_INTERVAL_MS=60000

#optional telegram bot
TELEGRAM_BOT_TOKEN="xxx"
TELEGRAM_DIFF_NOTIFICATIONS=true

#optional ntfy notification service
NTFY_SERVER_URL=
NTFY_ACCESS_TOKEN=
NTFY_TOPIC_PREFIX=
NTFY_DIFF_NOTIFICATIONS=false

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional dev fee configuration
DEV_FEE_ADDRESS=
DEV_FEE_PERCENT=1.5
# mainnet | testnet
NETWORK=mainnet

API_SECURE=false
POOL_IDENTIFIER="blitzpool"

# Database configuration
# --- SQLite (legacy/default) ---
# Uncomment the next two lines to run BlitzPool with the local SQLite database file.
#DB_TYPE=sqlite
#SQLITE_DATABASE=./DB/public-pool.sqlite

# --- Postgres (recommended for production) ---
# Set DB_TYPE=postgres and provide the connection details below. The docker-compose Postgres stacks
# persist data in ./data/<network>/public-pool/pg relative to this folder.
#DB_TYPE=postgres
#PG_HOST=postgres
#PG_PORT=5432
#PG_USER=postgres
# Provide either PG_PASSWORD directly or PG_PASSWORD_FILE to read it from a mounted secret.
#PG_PASSWORD=postgres
#PG_DATABASE=public_pool
#PG_SSL=false
#PG_PASSWORD_FILE=/run/secrets/pg_password
#DB_RUN_MIGRATIONS=true
# When DB_RUN_MIGRATIONS=true the compose stack copies existing SQLite data on startup.
# Comment in the line below to disable the automatic copy and run the migration script manually instead.
#DB_MIGRATE_SQLITE_ON_BOOT=false
