BITCOIN_RPC_URL=http://bitcoin
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_TIMEOUT=10000

# Enable in bitcoin.conf with
# zmqpubrawblock=tcp://*:3000
# BITCOIN_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=3334
STRATUM_PORT=3333
STRATUM_START_DIFFICULTY=16384
STRATUM_HIGH_DIFF_PORT=3339
STRATUM_HIGH_DIFF_START_DIFFICULTY=1000000

#block-template interval
BLOCK_TEMPLATE_INTERVAL=30000
JOB_RETENTION_MS=90000
# Toggle anomalous diff detection for rejected shares
ANOMALOUS_DIFF_DETECTION_ENABLED=true
# Desired number of shares per minute per worker for default port (default: 6)
TARGET_SHARES_PER_MINUTE=6
# Desired number of shares per minute per worker for high difficulty port (defaults to TARGET_SHARES_PER_MINUTE if not set)
STRATUM_HIGH_DIFF_TARGET_SHARES_PER_MINUTE=6
# Interval for checking and adjusting miner difficulty (ms)
DIFFICULTY_CHECK_INTERVAL_MS=60000

#optional telegram bot
TELEGRAM_BOT_TOKEN="xxx"
TELEGRAM_DIFF_NOTIFICATIONS=true

#optional ntfy notification service
NTFY_SERVER_URL=
NTFY_ACCESS_TOKEN=
NTFY_TOPIC_PREFIX=
NTFY_DIFF_NOTIFICATIONS=false

#optional UnifiedPush server (VAPID support)
# Leave commented out to use plain POST (ntfy compatible)
# Uncomment when ntfy adds VAPID support
# To generate keys: npx web-push generate-vapid-keys
#VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=
#VAPID_SUBJECT=mailto:admin@yourserver.com

# ========================================
# Firebase Cloud Messaging (FCM) - Optional
# ========================================
# Path to Firebase Admin SDK service account JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Leave empty to disable FCM (only UnifiedPush will work)
#FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-adminsdk-xxxxx.json

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional dev fee configuration
DEV_FEE_ADDRESS=
DEV_FEE_PERCENT=1.5
# mainnet | testnet
NETWORK=mainnet

# ============================================================================
# STRATUM V2 & JOB DECLARATION PROTOCOL (JDP) CONFIGURATION
# ============================================================================

# Stratum V2 Authority Keypair - Used for Noise NX handshake authentication
# Miners need your authority PUBLIC KEY to verify your pool's certificate
#
# Generate a new keypair (run this command):
#   node -e "const crypto=require('crypto');const secp=require('tiny-secp256k1');const priv=crypto.randomBytes(32);const pub=Buffer.from(secp.pointFromScalar(priv,true)).subarray(1,33);console.log('Private key (configure in pool):\\nSV2_AUTHORITY_PRIVKEY='+priv.toString('hex')+'\\n\\nPublic key (share with miners):\\nAuthority Public Key: '+pub.toString('hex')+'\\n\\n⚠️  Miners must configure this public key to connect to your pool')"
#
# Configure only the PRIVATE KEY in your pool:
#SV2_AUTHORITY_PRIVKEY=
#
# The pool will log the public key on startup - share it with your miners!
# You can also find it in the startup logs: "Authority public key (x-only): ..."
#
# ⚠️  IMPORTANT: If not set, a random key is generated on startup (miners can't reconnect after pool restart)

# Job Declaration Protocol (JDP) - Allows miners to declare custom block templates
# Enable this to let miners select transactions from their own Bitcoin nodes
# JDP gives miners full control over transaction selection (censorship resistance)
# Requires: Extended channels, coinbase output validation (if DEV_FEE_ADDRESS is set)
#SV2_JDP_ENABLED=false
#SV2_JDP_PORT=3337

# Pool Fee Validation for JDP
# If DEV_FEE_ADDRESS is set above, JDP miners MUST include pool fees in their coinbase
# Two-stage validation:
#   1. AllocateMiningJobToken: Miner proposes coinbase outputs for validation
#   2. DeclareMiningJob: Pool verifies outputs match and include correct pool fee
# Discovery endpoint: GET /api/info/sv2-pool-fees (explains full process + examples)
# If DEV_FEE_ADDRESS is empty, miners can use any coinbase outputs (no validation)

# ============================================================================
# PPLNS POOL MODE (Optional - runs alongside solo mining)
# ============================================================================

# Enable PPLNS by setting a dedicated port. Solo mining on existing ports
# remains unchanged. Miners connecting to the PPLNS port receive proportional
# coinbase payouts based on their share contribution (OCEAN/DATUM model).

# PPLNS port (leave commented out to disable PPLNS entirely)
#PPLNS_PORT=3340
# Starting difficulty for PPLNS port (defaults to STRATUM_START_DIFFICULTY)
#PPLNS_START_DIFFICULTY=16384
# Target shares per minute for PPLNS port (defaults to TARGET_SHARES_PER_MINUTE)
#PPLNS_TARGET_SHARES_PER_MINUTE=6

# Pool fee for PPLNS payouts (separate from solo DEV_FEE)
# This address receives the pool fee directly in the coinbase transaction
#PPLNS_FEE_ADDRESS=bc1q...
#PPLNS_FEE_PERCENT=2
# Coinbase weight budget in WU — must match bitcoin.conf blockreservedweight
# Default: 50000 (fits ~400 P2WPKH outputs). Set higher for more miners.
# Requires bitcoin.conf: blockreservedweight=50000
#PPLNS_COINBASE_WEIGHT_BUDGET=50000

# Notes:
# - PPLNS window size = 4 * network_difficulty (diff1-equivalent shares)
# - Miners below dust limit (546 sats) accumulate balance across blocks
# - Block payout processing runs on PM2 instance 0 only
# - API endpoints: GET /pplns/status, /pplns/distribution, /pplns/:address, /pplns/:address/history

API_SECURE=false
POOL_IDENTIFIER="blitzpool"

# Database configuration
# --- SQLite (legacy/default) ---
# Uncomment the next two lines to run BlitzPool with the local SQLite database file.
#DB_TYPE=sqlite
#SQLITE_DATABASE=./DB/public-pool.sqlite

# --- Postgres (recommended for production) ---
# Set DB_TYPE=postgres and provide the connection details below. The docker-compose Postgres stacks
# persist data in ./data/<network>/public-pool/pg relative to this folder.
#DB_TYPE=postgres
#PG_HOST=postgres
#PG_PORT=5432
#PG_USER=postgres
# Provide either PG_PASSWORD directly or PG_PASSWORD_FILE to read it from a mounted secret.
#PG_PASSWORD=postgres
#PG_DATABASE=public_pool
#PG_SSL=false
#PG_PASSWORD_FILE=/run/secrets/pg_password
#DB_RUN_MIGRATIONS=true
# When DB_RUN_MIGRATIONS=true the compose stack copies existing SQLite data on startup.
# Comment in the line below to disable the automatic copy and run the migration script manually instead.
#DB_MIGRATE_SQLITE_ON_BOOT=false

# ============================================================================
# STATISTICS COORDINATION - Simplified Architecture
# ============================================================================

# Statistics are now coordinated automatically:
# - All PM2 instances write shares to Redis immediately (atomic operations)
# - Instance 0 flushes Redis → Database every 60 seconds
# - No configuration needed - works out of the box!
#
# This eliminates data loss on crashes and SQLite locking issues.

# API Cache TTLs - Optimized defaults in code (override only if needed):
#   - chart: 10 seconds (fast updates)
#   - shares/workers/accepted/rejected: 60 seconds (aligned with flush)
#   - pool info: 10 minutes (changes rarely)
#
# Custom TTL overrides (uncomment to customize):
#API_CACHE_TTL_SITE_INFO=300
#API_CACHE_TTL_POOL_INFO=600
#API_CACHE_TTL_CORE_INFO=60
#API_CACHE_TTL_PEER_INFO=60
#API_CACHE_TTL_CHART=10
#API_CACHE_TTL_SHARES=60
#API_CACHE_TTL_WORKERS=60
#API_CACHE_TTL_ACCEPTED=60
#API_CACHE_TTL_REJECTED=60

# ============================================================================
# REDIS CONFIGURATION - Required for statistics coordination
# ============================================================================

# Redis is REQUIRED for the statistics system to work
# All PM2 instances write statistics to Redis with atomic operations
# Uncomment REDIS_HOST to enable (required for PM2 cluster mode)
#REDIS_HOST=redis
#REDIS_PORT=6379
# Redis password (optional) - Set this in your .env file to secure Redis
# If set, Redis server will require authentication
#REDIS_PASSWORD=your_secure_password_here
#REDIS_DB=0
#REDIS_TTL=600
# Redis memory limit (used by docker-compose)
#REDIS_MAX_MEMORY=256mb

# ============================================================================
# AGGREGATION SERVICE - Background pre-computed queries (runs on instance 0 only)
# ============================================================================

# Pre-computed aggregations reduce database load for expensive queries
# Set to 'false' to disable (useful for development)
ENABLE_AGGREGATION_SERVICE=true
# Pool stats aggregation interval (ms) - Default: 10 min
AGGREGATION_INTERVAL_POOL_STATS=600000
# Chart data aggregation interval (ms) - Default: 5 min
AGGREGATION_INTERVAL_CHART_DATA=300000

# ============================================================================
# DATABASE CONNECTION POOLING
# ============================================================================

# PostgreSQL connection pooling configuration
# Pool size per PM2 instance - Formula: (max_connections / PM2_INSTANCES) - 2
# Example: 100 max connections / 4 instances = 25 per instance - 2 = 23
#PG_POOL_SIZE=10
# Maximum query execution time (ms) - Queries exceeding this will be terminated
#PG_MAX_QUERY_TIME=30000
# Connection acquisition timeout (ms) - Wait time to get connection from pool
#PG_ACQUIRE_TIMEOUT=60000
# Idle connection timeout (ms) - Time before idle connection is closed
#PG_IDLE_TIMEOUT=10000

# SQLite performance tuning (for SQLite users)
# Busy timeout (ms) - Wait time when database is locked
#SQLITE_BUSY_TIMEOUT=30000
# Cache size in KB (negative value) or pages (positive) - Default: 64MB
#SQLITE_CACHE_SIZE=-64000

# Worker threads for CPU-intensive operations (experimental)
# Set to 'true' to enable worker thread pool (currently framework only)
#ENABLE_WORKER_THREADS=false
# Number of worker threads - Defaults to (CPU cores - 1)
#WORKER_THREAD_POOL_SIZE=3

# Prometheus metrics endpoint is always available at: http://localhost:3334/metrics
# Health check endpoint is always available at: http://localhost:3334/health
